rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwnerMode() {
      return signedIn() && request.auth.token.email in [
        'alexbryantwork3234@outlook.com',
        'meganbullock881@yahoo.com'
      ];
    }

    function billingMaxMembers() {
      return isOwnerMode() ? 9999 : (
        resource.data.keys().hasAny(['ownerUid'])
          && exists(/databases/$(database)/documents/users/$(resource.data.ownerUid)/billing/main)
          ? get(/databases/$(database)/documents/users/$(resource.data.ownerUid)/billing/main).data.maxMembers
          : 1
      );
    }

    function isMember() {
      return signedIn()
        && request.auth.uid in resource.data.memberUids;
    }

    function isCalendarOwner() {
      return signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    function isJoining() {
      return signedIn()
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.auth.uid in request.resource.data.memberUids
        && !(request.auth.uid in resource.data.memberUids)
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
        && request.resource.data.memberEmails.size() == resource.data.memberEmails.size() + 1
        && request.resource.data.memberUids.size() <= billingMaxMembers()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberUids',
          'memberEmails'
      ]);
    }

    function isOwnerRemovingMember() {
      return isCalendarOwner()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.memberUids.size() < resource.data.memberUids.size()
        && request.resource.data.memberUids.size() >= 1
        && request.resource.data.memberEmails.size() == request.resource.data.memberUids.size()
        && resource.data.memberUids.hasAll(request.resource.data.memberUids)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberUids',
          'memberEmails',
          'updatedAt'
        ]);
    }

    function isLeavingMember() {
      return isMember()
        && resource.data.ownerUid != request.auth.uid
        && !(request.auth.uid in request.resource.data.memberUids)
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1
        && request.resource.data.memberEmails.size() == resource.data.memberEmails.size() - 1
        && request.resource.data.memberUids.hasAll([resource.data.ownerUid])
        && resource.data.memberUids.hasAll(request.resource.data.memberUids)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberUids',
          'memberEmails',
          'updatedAt'
        ]);
    }

    match /users/{userId}/planner/main {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/billing/main {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /sharedCalendars/{calendarId} {
      allow create: if signedIn()
        && request.resource.data.memberUids.size() == 1
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.memberEmails.size() == 1
        && (!request.resource.data.keys().hasAny(['ownerUid'])
          || request.resource.data.ownerUid == request.auth.uid)
        && request.resource.data.state is map;

      allow read: if isMember();

      allow update: if (
          isMember()
          && !(resource.data.keys().hasAny(['ownerUid']))
          && request.resource.data.ownerUid == resource.data.memberUids[0]
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'ownerUid',
            'planKey',
            'maxMembers'
          ])
        )
        || isJoining()
        || isOwnerRemovingMember()
        || isLeavingMember()
        || (isMember()
          && request.resource.data.memberUids == resource.data.memberUids
          && request.resource.data.memberEmails == resource.data.memberEmails
          && request.resource.data.inviteCode == resource.data.inviteCode
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'state',
            'updatedAt'
          ]));

      allow delete: if isMember() && resource.data.memberUids.size() == 1;
    }
  }
}
